.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fff5f7 0%, #ffe4ec 50%, #ffd6e4 100%);
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
  position: relative;
  overflow: hidden;
}

.intro-stack {
  transition: transform 0.45s ease, opacity 0.45s ease, filter 0.45s ease;
}

.intro-stack-exit {
  opacity: 0;
  transform: translateY(-120rpx) scale(0.98);
  filter: blur(8rpx);
}

.hero-card,
.tips-card,
.panel-card {
  background: linear-gradient(145deg, #ffffff 0%, #fff7fb 100%);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(214, 51, 108, 0.1);
  box-shadow: 0 6rpx 24rpx rgba(214, 51, 108, 0.08);
}

.hero-title,
.tips-title,
.panel-title,
.section-title {
  font-size: 32rpx;
  color: #d6336c;
  font-weight: 700;
}

.hero-desc,
.tips-desc,
.panel-desc,
.section-desc,
.invite-code-expire {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9a7a7a;
}

.hero-eyebrow {
  font-size: 22rpx;
  color: #f72585;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.pair-badge {
  display: inline-block;
  margin-top: 20rpx;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pair-badge.bound {
  color: #ffffff;
  background: linear-gradient(135deg, #f72585 0%, #d6336c 100%);
}

.pair-badge.unbound {
  color: #d6336c;
  background: rgba(214, 51, 108, 0.1);
}

.bound-card {
  background: linear-gradient(145deg, #fff7fb 0%, #fff0f7 100%);
}

.bound-panel-card {
  margin-top: 120rpx;
}

.bound-panel-title {
  margin-top: 20rpx;
}

.celebration-entry-btn {
  margin-top: 28rpx;
}

.danger-btn {
  width: 100%;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 20rpx;
  background: rgba(214, 51, 108, 0.08);
  color: #d6336c;
  border: 2rpx solid rgba(214, 51, 108, 0.18);
}

.section-block {
  margin-top: 8rpx;
}

.divider {
  height: 2rpx;
  background: rgba(214, 51, 108, 0.1);
  margin: 28rpx 0;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  width: 100%;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #f72585 0%, #d6336c 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(214, 51, 108, 0.18);
}

.secondary-btn,
.ghost-btn {
  background: #ffffff;
  color: #d6336c;
  border: 2rpx solid rgba(214, 51, 108, 0.22);
}

.bind-btn {
  margin-top: 24rpx;
}

.pair-input {
  width: 100%;
  height: 88rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #fffafb;
  border: 2rpx solid rgba(214, 51, 108, 0.14);
  box-sizing: border-box;
  font-size: 28rpx;
  color: #3d2d2d;
}

.invite-code-box {
  margin-top: 20rpx;
  background: linear-gradient(145deg, #fff0f5 0%, #ffe7f0 100%);
  border: 2rpx dashed rgba(214, 51, 108, 0.28);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  text-align: center;
}

.invite-code-label {
  font-size: 24rpx;
  color: #9a7a7a;
}

.invite-code-value {
  margin: 14rpx 0 10rpx;
  font-size: 44rpx;
  line-height: 1.2;
  color: #d6336c;
  font-weight: 800;
  letter-spacing: 6rpx;
}

.celebration-screen {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: radial-gradient(circle at top, rgba(255, 255, 255, 0.96) 0%, rgba(255, 240, 246, 0.98) 48%, #ffdce9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.celebration-panel {
  position: relative;
  width: 100%;
  padding: 88rpx 44rpx 56rpx;
  border-radius: 40rpx;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 245, 249, 0.98) 100%);
  box-shadow: 0 24rpx 80rpx rgba(214, 51, 108, 0.16);
  text-align: center;
  animation: celebrationPanelIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}

.celebration-kicker {
  font-size: 24rpx;
  color: #f72585;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.celebration-title {
  margin-top: 26rpx;
  font-size: 52rpx;
  line-height: 1.35;
  color: #d6336c;
  font-weight: 800;
}

.celebration-desc {
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #8b6b6b;
}

.celebration-cta {
  width: 100%;
  margin-top: 44rpx;
  min-height: 104rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff4d94 0%, #d6336c 55%, #b5179e 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 104rpx;
  box-shadow: 0 18rpx 40rpx rgba(214, 51, 108, 0.25);
}

.celebration-ring {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.7);
  animation: ringPulse 2.4s ease-out infinite;
}

.celebration-ring-one {
  width: 420rpx;
  height: 420rpx;
}

.celebration-ring-two {
  width: 560rpx;
  height: 560rpx;
  animation-delay: 0.35s;
}

.celebration-float {
  position: absolute;
  bottom: 220rpx;
  font-size: 42rpx;
  animation: celebrateFloat 2.8s ease-in forwards;
  opacity: 0;
}

@keyframes celebrationPanelIn {
  0% {
    opacity: 0;
    transform: translateY(48rpx) scale(0.92);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes ringPulse {
  0% {
    transform: scale(0.72);
    opacity: 0.55;
  }
  100% {
    transform: scale(1.16);
    opacity: 0;
  }
}

@keyframes celebrateFloat {
  0% {
    transform: translateY(0) scale(0.8) rotate(-8deg);
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  100% {
    transform: translateY(-520rpx) scale(1.18) rotate(10deg);
    opacity: 0;
  }
}