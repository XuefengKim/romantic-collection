/* pages/index/index.wxss */

/* ========== 基础布局 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fff5f7 0%, #ffe4ec 50%, #ffd6e4 100%);
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

/* ========== 数据看板 ========== */
.stats-card {
  background: linear-gradient(145deg, #ffffff 0%, #fff9fb 100%);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(214, 51, 108, 0.1);
  margin-bottom: 32rpx;
  border: 1px solid rgba(214, 51, 108, 0.08);
}

.title {
  font-size: 42rpx;
  color: #d6336c;
  font-weight: 800;
  text-align: center;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #b38888;
  text-align: center;
  margin-bottom: 36rpx;
  font-weight: 400;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
}

.stats-number {
  font-size: 60rpx;
  color: #d6336c;
  font-weight: 800;
}

.stats-number.highlight {
  background: linear-gradient(135deg, #f72585 0%, #d6336c 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stats-label {
  font-size: 28rpx;
  color: #5a4545;
  margin-top: 8rpx;
  font-weight: 500;
}

.stats-hint {
  font-size: 22rpx;
  color: #c49a9a;
  margin-top: 12rpx;
}

/* ========== 绑定状态入口 ========== */
.pair-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fff7fb 100%);
  border-radius: 24rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 32rpx;
  border: 1px solid rgba(214, 51, 108, 0.1);
  box-shadow: 0 6rpx 24rpx rgba(214, 51, 108, 0.08);
}

.pair-status-main {
  flex: 1;
}

.pair-status-label {
  font-size: 28rpx;
  color: #d6336c;
  font-weight: 700;
}

.pair-status-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9a7a7a;
}

.pair-status-side {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.pair-status-badge {
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.pair-status-badge.bound {
  color: #ffffff;
  background: linear-gradient(135deg, #f72585 0%, #d6336c 100%);
}

.pair-status-badge.unbound {
  color: #d6336c;
  background: rgba(214, 51, 108, 0.1);
}

.pair-status-arrow {
  font-size: 36rpx;
  line-height: 1;
  color: #d6336c;
}

/* ========== 抽卡区域 - 优化 ========== */
.draw-section {
  margin-bottom: 32rpx;
}

.draw-btn {
  width: 100%;
  background: linear-gradient(135deg, #d6336c 0%, #f72585 100%);
  color: white;
  border-radius: 50rpx;
  padding: 32rpx 0;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(214, 51, 108, 0.35);
  letter-spacing: 2rpx;
}

/* 新增：暂无抽卡机会卡片 */
.draw-empty {
  background: linear-gradient(145deg, #fff0f5 0%, #ffe4ee 100%);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  border: 2rpx solid rgba(214, 51, 108, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(214, 51, 108, 0.08);
}

.draw-empty-icon {
  font-size: 36rpx;      /* emoji 用这个 */
  width: 72rpx;          /* 图片用这个（优先） */
  height: 72rpx;
  margin-bottom: 16rpx;
  display: flex;          /* flex 居中 */
  align-items: center;
  justify-content: center;
}


.draw-empty-text {
  font-size: 32rpx;
  color: #d6336c;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.draw-empty-hint {
  font-size: 24rpx;
  color: #c49a9a;
}

/* ========== 任务区域 ========== */
.tasks-section {
  margin-bottom: 32rpx;
}

/* 任务分类卡片 - 优化版（浪漫任务） */
.task-category {
  border-radius: 28rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 28rpx;
}

/* 浪漫任务：渐变背景 + 阴影 + 精致边框 */
.task-category.romantic {
  background: linear-gradient(160deg, #fff5f9 0%, #ffe4f0 50%, #ffd6e8 100%);
  border: 1px solid rgba(114, 9, 183, 0.12);
  box-shadow: 
    0 4rpx 20rpx rgba(114, 9, 183, 0.08),
    0 8rpx 32rpx rgba(233, 30, 99, 0.06);
}

/* 家务任务：保持粉色系风格 */
.task-category.housework {
  background: linear-gradient(160deg, #fff5f7 0%, #ffe8ee 50%, #ffd6e4 100%);
  border: 1px solid rgba(214, 51, 108, 0.12);
  box-shadow: 
    0 4rpx 20rpx rgba(214, 51, 108, 0.08),
    0 8rpx 32rpx rgba(233, 30, 99, 0.06);
}

/* 分类标题 - 优化版 */
.category-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.category-icon {
  font-size: 36rpx;      /* emoji 用这个 */
  width: 72rpx;          /* 图片用这个（优先） */
  height: 72rpx;
  margin-right: 12rpx;
  vertical-align: middle; /* 两者都垂直居中 */
}

.category-text {
  font-size: 32rpx;
  font-weight: 700;
}

.task-category.romantic .category-text {
  color: #7209b7;
}

.task-category.housework .category-text {
  color: #d6336c;
}

/* 新增：区块统一提示 */
.section-hint {
  font-size: 24rpx;
  color: #d6336c;
  opacity: 0.8;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 任务项 - 优化版 */
.task-item {
  background: linear-gradient(145deg, #ffffff 0%, #fffcfd 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1px solid rgba(214, 51, 108, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

/* 浪漫任务项：淡紫色边框 */
.task-category.romantic .task-item {
  border-color: rgba(114, 9, 183, 0.1);
}

/* 家务任务项：淡粉色边框 */
.task-category.housework .task-item {
  border-color: rgba(214, 51, 108, 0.1);
}

.task-item:active {
  transform: scale(0.98);
}

.task-info {
  flex: 1;
  padding-right: 24rpx;
}

.task-name {
  font-size: 30rpx;
  color: #3d2d2d;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #9a7a7a;
  line-height: 1.5;
}

/* ========== 打卡按钮 - 优化版 ========== */
.checkin-btn {
  background: linear-gradient(135deg, #f72585 0%, #e91e8c 100%);
  color: white;
  border-radius: 50rpx;
  height: 84rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  min-width: 144rpx;
  max-width: 180rpx;
  box-shadow: 0 4rpx 12rpx rgba(247, 37, 133, 0.3);
  line-height: 84rpx;
  flex-shrink: 0;
}

.checkin-btn.cooldown {
  background: linear-gradient(135deg, #e8e8e8 0%, #d8d8d8 100%);
  color: #a0a0a0;
  box-shadow: none;
}

/* ========== 导航区域 ========== */
.nav-section {
  margin-top: 48rpx;
}

.nav-btn {
  width: 100%;
  background: linear-gradient(145deg, #ffffff 0%, #fff9fb 100%);
  color: #d6336c;
  border: 2rpx solid rgba(214, 51, 108, 0.3);
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(214, 51, 108, 0.1);
}

.nav-btn.rank-btn.hidden {
  display: none;
}

/* ========== 弹窗 ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  animation: modalIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalIn {
  0% {
    transform: scale(0.7) rotate(-10deg);
    opacity: 0;
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.card-result {
  padding: 60rpx 40rpx 48rpx;
  text-align: center;
  position: relative;
}

.rarity-tag {
  display: inline-block;
  color: white;
  font-size: 26rpx;
  font-weight: bold;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid white;
}

.card-name {
  color: white;
  font-size: 42rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.card-desc {
  color: rgba(255, 255, 255, 0.95);
  font-size: 28rpx;
  line-height: 1.6;
}

.count-info {
  color: rgba(255, 255, 255, 0.95);
  font-size: 26rpx;
  margin-top: 24rpx;
  font-weight: 500;
}

.close-btn {
  width: 100%;
  background: #f8f8f8;
  color: #5a4545;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 0;
}

/* 稀有度动画 */
.modal-content.SSR, .modal-content.UR {
  animation: modalIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), rarityGlow 1.5s ease-in-out infinite;
}

@keyframes rarityGlow {
  0%, 100% { box-shadow: 0 0 0 rgba(247, 37, 133, 0); }
  50% { box-shadow: 0 0 60rpx 20rpx rgba(247, 37, 133, 0.4); }
}

/* ========== 漂浮爱心 ========== */
.floating-heart {
  position: fixed;
  bottom: 0;
  font-size: 44rpx;
  animation: floatUp 3.5s linear forwards;
  z-index: 999;
  pointer-events: none;
}

@keyframes floatUp {
  0% {
    transform: translateY(0) scale(0.5);
    opacity: 1;
  }
  100% {
    transform: translateY(-900rpx) scale(1.2);
    opacity: 0;
  }
}
