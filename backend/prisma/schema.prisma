generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int       @id @default(autoincrement())
  openid      String    @unique @db.VarChar(64)
  unionid     String?   @db.VarChar(64)
  nickname    String?   @db.VarChar(64)
  avatarUrl   String?   @db.VarChar(255)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  stats       UserStat?
  inviteCodes InviteCode[]
  checkins    CheckinRecord[]
  draws       DrawRecord[]
  cards       UserCardCollection[]
}

model CouplePair {
  id          Int      @id @default(autoincrement())
  userAId     Int
  userBId     Int
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model InviteCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(16)
  creatorId   Int
  status      String   @default("active") @db.VarChar(20)
  expiresAt   DateTime
  usedById    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([usedById])
}

model UserStat {
  id                          Int      @id @default(autoincrement())
  userId                      Int      @unique
  totalHearts                 Int      @default(0)
  drawChances                 Int      @default(0)
  totalDrawEarned             Int      @default(0)
  totalDrawUsed               Int      @default(0)
  fullCollectionAchievementShown Boolean @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  user                        User     @relation(fields: [userId], references: [id])
}

model TaskCatalog {
  id          Int      @id
  category    String   @db.VarChar(32)
  name        String   @db.VarChar(128)
  description String   @db.VarChar(255)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  checkins    CheckinRecord[]
}

model CardCatalog {
  id          Int      @id
  name        String   @db.VarChar(128)
  rarity      String   @db.VarChar(16)
  description String   @db.VarChar(255)
  color       String   @db.VarChar(16)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  draws       DrawRecord[]
  collections UserCardCollection[]
}

model CheckinRecord {
  id          Int      @id @default(autoincrement())
  userId      Int
  taskId      Int
  heartsDelta Int      @default(1)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  task        TaskCatalog @relation(fields: [taskId], references: [id])

  @@index([userId, createdAt])
  @@index([taskId])
}

model DrawRecord {
  id          Int      @id @default(autoincrement())
  userId      Int
  cardId      Int
  rarity      String   @db.VarChar(16)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  card        CardCatalog @relation(fields: [cardId], references: [id])

  @@index([userId, createdAt])
  @@index([cardId])
}

model UserCardCollection {
  id          Int      @id @default(autoincrement())
  userId      Int
  cardId      Int
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  card        CardCatalog @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
}
